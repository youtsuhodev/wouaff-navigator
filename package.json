{
  "name": "wouaff",
  "version": "1.0.3",
  "description": "Wouaff - Navigateur internet basé sur Electron et Chromium",
  "author": "Wouaff",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.wouaff.browser",
    "productName": "Wouaff",
    "directories": {
      "output": "build-out"
    },
    "files": [
      "main.js",
      "preload.js",
      "rpc.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/logo/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Wouaff",
      "installerIcon": "assets/logo/icon.ico",
      "uninstallerIcon": "assets/logo/icon.ico",
      "license": null,
      "language": "1040",
      "unicode": true
    },
    "publish": {
      "provider": "github",
      "owner": "youtsuhodev",
      "repo": "wouaff-navigator",
      "releaseType": "release"
    }
  },
  "keywords": [
    "browser",
    "electron",
    "chromium"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "bootstrap-icons": "^1.13.1",
    "electron-updater": "^6.8.9"
  }
}
